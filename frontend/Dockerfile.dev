FROM node:20-bookworm

WORKDIR /app

# Copy only package files first so the install layer is cached unless they change.
COPY package.json package-lock.json* bun.lock* /app/
COPY frontend/package.json /app/frontend/package.json

# One workspace install installs root + frontend dependencies.
RUN npm install

# Copy source after install so code changes don't bust the install cache.
COPY ./frontend /app/frontend

WORKDIR /app/frontend

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
