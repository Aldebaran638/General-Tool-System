# Core app settings
PROJECT_NAME=通用工具系统
STACK_NAME=general-tool-system
COMPOSE_PROJECT_NAME=general-tool-system
ENVIRONMENT=local
DOMAIN=localhost
FRONTEND_HOST=http://localhost:15173
BACKEND_CORS_ORIGINS=http://localhost:15173,http://127.0.0.1:15173

# Image tags used by compose.yml
TAG=latest
DOCKER_IMAGE_BACKEND=general-tool-system-backend
DOCKER_IMAGE_FRONTEND=general-tool-system-frontend

# Security and bootstrap user
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_TEST_DB=app_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=通用工具系统

# ── 试卷 / 题库文件存储目录 ────────────────────────────────────────────────────
# 相对路径：相对于项目根目录（包含 pyproject.toml 的目录），适合开发环境。
#   UPLOAD_DIR=backend/app/uploads/
#
# 绝对路径：适合生产环境或将文件存放在宿主机指定目录。
#   UPLOAD_DIR=/data/exam-papers/
#
# Docker 说明：使用绝对路径时，需在 compose 中为 backend 服务添加 volume：
#   services:
#     backend:
#       volumes:
#         - /data/exam-papers:/data/exam-papers
#
# 启动时系统会自动创建目录并进行写权限验证；验证失败会阻止服务启动。
# 可调用 GET /api/v1/utils/storage-info/ 检查当前配置状态（需超管权限）。
UPLOAD_DIR=backend/app/uploads/

# Observability
SENTRY_DSN=

# Test and CI flags
CI=
